# Copy this file to .env and fill in your values (never commit the real .env).
# Get a free Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Vision-capable Gemini model (gemini-2.5-flash is verified working / free tier).
MODEL=gemini-2.5-flash

# --- Provider chain (tried in order; each is used if the previous one fails) ---
# 1) GEMINI_API_KEY  + MODEL       (above)
# 2) GEMINI_API_KEY2 + MODEL2      (second Gemini key)
# 3) GITHUB_TOKEN    + FALLBACK_MODEL   (GitHub Models gpt-4o-mini)
# 4) GITHUB_TOKEN2   + FALLBACK_MODEL2  (second GitHub token)
# Any slot with a blank key/token is skipped. All are optional except #1.
GEMINI_API_KEY2=your_second_gemini_key_here
MODEL2=gemini-2.5-flash

GITHUB_TOKEN=your_github_models_token_here
FALLBACK_MODEL=openai/gpt-4o-mini

GITHUB_TOKEN2=your_second_github_token_here
FALLBACK_MODEL2=openai/gpt-4o-mini

# Local dev server port
PORT=3001
